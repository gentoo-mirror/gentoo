DEFINED_PHASES=-
DESCRIPTION=Meta ebuild for LXQt, the Lightweight Desktop Environment
EAPI=8
HOMEPAGE=https://lxqt-project.org/
IUSE=+about admin +archiver +desktop-portal +display-manager +filemanager +icons +lximage nls +policykit powermanagement +processviewer +screenshot +sddm ssh-askpass +sudo +terminal +trash wayland +window-manager
KEYWORDS=~amd64 ~arm64 ~ppc64 ~riscv ~x86
LICENSE=metapackage
RDEPEND==lxqt-base/lxqt-config-2.4* =lxqt-base/lxqt-globalkeys-2.4* =lxqt-base/lxqt-menu-data-2.4* =lxqt-base/lxqt-notificationd-2.4* =lxqt-base/lxqt-panel-2.4* =lxqt-base/lxqt-qtplugin-2.4* =lxqt-base/lxqt-runner-2.4* =lxqt-base/lxqt-session-2.4* virtual/ttf-fonts x11-terms/xterm =x11-themes/lxqt-themes-2.4* about? ( =lxqt-base/lxqt-about-2.4* ) admin? ( =lxqt-base/lxqt-admin-2.4* ) archiver? ( >=app-arch/lxqt-archiver-1.4 ) desktop-portal? ( >=gui-libs/xdg-desktop-portal-lxqt-1.4 ) display-manager? ( sddm? ( x11-misc/sddm ) !sddm? ( x11-misc/lightdm ) ) filemanager? ( =x11-misc/pcmanfm-qt-2.4* ) icons? ( kde-frameworks/breeze-icons:6 ) lximage? ( =media-gfx/lximage-qt-2.4* ) nls? ( dev-qt/qttranslations:6 ) policykit? ( =lxqt-base/lxqt-policykit-2.4* ) powermanagement? ( =lxqt-base/lxqt-powermanagement-2.4* ) processviewer? ( >=x11-misc/qps-2.13 ) screenshot? ( >=x11-misc/screengrab-3.2 ) sddm? ( x11-misc/sddm ) ssh-askpass? ( =lxqt-base/lxqt-openssh-askpass-2.4* ) sudo? ( =lxqt-base/lxqt-sudo-2.4* ) terminal? ( =x11-terms/qterminal-2.4* ) trash? ( gnome-base/gvfs ) wayland? ( lxqt-base/lxqt-wayland-session ) window-manager? ( kde-plasma/systemsettings:6 wayland? ( kde-plasma/kwin:6 ) !wayland? ( kde-plasma/kwin-x11:6 ) )
REQUIRED_USE=trash? ( filemanager )
SLOT=0
_md5_=2ad4fb229422b045e7ff143b61afe66c
