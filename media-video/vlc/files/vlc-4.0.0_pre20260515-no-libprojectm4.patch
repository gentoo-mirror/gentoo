From 13c95e4694cc9b13d47d2b302ff09a289e19454b Mon Sep 17 00:00:00 2001
From: Andreas Sturmlechner <asturm@gentoo.org>
Date: Fri, 15 May 2026 14:01:57 +0200
Subject: [PATCH] visualization: Revert "update projectM module to support
 libprojectM v4"

This reverts commit 13fb39ea54971deba8c52ce6eb9d635fa8c5cbfa and
fabf83c23030bd5e63f07abb831e3bf64c63ac96 ("configure: don't set HAVE_PROJECTM
compiler flags globally")
---
 configure.ac | 20 ++++++--------------
 1 file changed, 6 insertions(+), 14 deletions(-)

diff --git a/configure.ac b/configure.ac
index 2ecfc7a099..a4d430717d 100644
--- a/configure.ac
+++ b/configure.ac
@@ -4688,23 +4688,15 @@ AC_ARG_ENABLE([projectm],
   AS_HELP_STRING([--enable-projectm], [projectM visualization plugin (default enabled)]))
 AS_IF([test "${enable_projectm}" != "no"],
   [
-    PKG_CHECK_MODULES(PROJECTM, [projectM-4],
+    PKG_CHECK_MODULES(PROJECTM, libprojectM,
     [
       VLC_ADD_PLUGIN([projectm])
-      VLC_ADD_CPPFLAGS([projectm],[-DHAVE_PROJECTM4])
-    ],
-    [
-      PKG_CHECK_MODULES(PROJECTM, [libprojectM],
-      [
-        VLC_ADD_PLUGIN([projectm])
-        PKG_CHECK_EXISTS([libprojectM >= 2.0.0],
-          [ VLC_ADD_CPPFLAGS([projectm],[-DHAVE_PROJECTM2 -std=gnu++14]) ],
-          [ AC_MSG_WARN( [Using libprojectM version 1] ) ]
-        )
-      ],
-      [
-        AC_MSG_WARN([${PROJECTM_PKG_ERRORS}.])
+      PKG_CHECK_EXISTS([libprojectM >= 2.0.0],
+        [ VLC_ADD_CPPFLAGS([projectm],[-DHAVE_PROJECTM2 -std=gnu++14]) ],
+        [ AC_MSG_WARN( [Using libprojectM version 1] )
       ])
+    ],[
+      AC_MSG_WARN([${PROJECTM_PKG_ERRORS}.])
     ])
   ])
 
-- 
2.54.0

